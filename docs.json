{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "FaturaDev Dokümantasyonu",
  "description": "FaturaDev e-Belge Gateway, ürün ve geliştirici dokümantasyonu",
  "colors": {
    "primary": "#141414",
    "light": "#FAFAFA",
    "dark": "#141414"
  },
  "logo": {
    "light": "/images/brand/fatura-icon.png",
    "dark": "/images/brand/fatura-icon.png",
    "href": "/"
  },
  "favicon": "/images/brand/fatura-icon.png",
  "seo": {
    "metatags": {
      "canonical": "https://fatura.dev"
    }
  },
  "appearance": {
    "default": "system",
    "strict": false
  },
  "interaction": {
    "drilldown": false
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": "system"
  },
  "contextual": {
    "options": ["copy", "view"]
  },
  "navigation": {
    "languages": [
      {
        "language": "tr",
        "default": true,
        "tabs": [
          {
            "tab": "Başlangıç",
            "icon": "rocket",
            "groups": [
              {
                "group": "Hoş geldiniz",
                "pages": [
                  "index",
                  "getting-started/key-features",
                  "quickstart"
                ]
              },
              {
                "group": "Temel kavramlar",
                "pages": [
                  "getting-started/core-concepts/e-document-gateway",
                  "getting-started/core-concepts/responsibility-model"
                ]
              }
            ]
          },
          {
            "tab": "Ürün Rehberi",
            "icon": "book-open",
            "groups": [
              {
                "group": "Genel Bakış",
                "pages": [
                  "user-guide/introduction",
                  "user-guide/use-cases"
                ]
              },
              {
                "group": "Kaynaklar",
                "pages": ["project/brand-assets"]
              },
              {
                "group": "e-Belge rehberleri",
                "pages": [
                  "user-guide/e-documents/overview",
                  "user-guide/e-documents/e-invoice",
                  "user-guide/e-documents/e-archive-invoice",
                  "user-guide/e-documents/e-dispatch",
                  "user-guide/e-documents/e-self-employment-receipt",
                  "user-guide/e-documents/e-producer-receipt",
                  "user-guide/e-documents/e-ticket"
                ]
              }
            ]
          },
          {
            "tab": "Geliştiriciler",
            "icon": "brackets-curly",
            "groups": [
              {
                "group": "Genel Bakış",
                "pages": ["developers/introduction"]
              }
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Hızlı başlangıç",
      "href": "/quickstart"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/FaturaDev"
    }
  }
}
