{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "FaturaDev Developers",
  "description": "FaturaDev e-Belge gateway ve API dokümantasyonu",
  "colors": {
    "primary": "#141414",
    "light": "#FAFAFA",
    "dark": "#141414"
  },
  "logo": {
    "light": "/images/brand/fatura-icon.png",
    "dark": "/images/brand/fatura-icon.png",
    "href": "/"
  },
  "favicon": "/images/brand/fatura-icon.png",
  "seo": {
    "metatags": {
      "canonical": "https://fatura.dev"
    }
  },
  "appearance": {
    "default": "system",
    "strict": false
  },
  "interaction": {
    "drilldown": false
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": "system"
  },
  "contextual": {
    "options": ["copy", "view"]
  },
  "navigation": {
    "languages": [
      {
        "language": "tr",
        "default": true,
        "tabs": [
          {
            "tab": "Dokümantasyon",
            "icon": "book-open",
            "groups": [
              {
                "group": "Genel Bakış",
                "pages": ["index"]
              },
              {
                "group": "Başlangıç",
                "pages": ["quickstart"]
              },
              {
                "group": "Kaynaklar",
                "pages": ["project/brand-assets"]
              }
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Dokümantasyonu keşfet",
      "href": "/quickstart"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/FaturaDev"
    }
  }
}
