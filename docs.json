{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "FaturaDev",
  "description": "Çok sağlayıcılı e-Belge API, gateway ve orkestrasyon platformu.",
  "colors": {
    "primary": "#000000",
    "light": "#FFFFFF",
    "dark": "#737373"
  },
  "favicon": "/images/brand/fatura-icon.png",
  "navigation": {
    "pages": [
      {
        "group": "Başlangıç",
        "pages": [
          "index",
          "quickstart"
        ]
      },
      {
        "group": "Proje",
        "pages": [
          "project/brand-assets"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/FaturaDev",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/images/brand/fatura-type.svg",
    "dark": "/images/brand/fatura-icon.png",
    "href": "https://fatura.dev"
  },
  "navbar": {
    "links": [
      {
        "type": "github",
        "href": "https://github.com/FaturaDev"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Uygulamaya git",
      "href": "https://app.fatura.dev"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/FaturaDev"
    }
  }
}
